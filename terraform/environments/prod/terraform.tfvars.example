###############################################################################
# prod environment — example variables
#
#   cp terraform.tfvars.example terraform.tfvars
#
# REMEMBER: also replace <account_id> in backend.tf with your real account id.
###############################################################################

aws_region  = "us-east-1"
project     = "my-project"
environment = "prod"

# --- Networking (distinct CIDR from dev so the VPCs could be peered) ---
vpc_cidr             = "10.1.0.0/16"
public_subnet_cidrs  = ["10.1.0.0/20", "10.1.16.0/20", "10.1.32.0/20"]
private_subnet_cidrs = ["10.1.64.0/20", "10.1.80.0/20", "10.1.96.0/20"]

# --- EKS ---
kubernetes_version = "1.30"

# SECURITY (prod): DO NOT leave this as 0.0.0.0/0. Restrict to your VPN/office.
endpoint_public_access_cidrs = ["203.0.113.0/24"] # <- replace with real ranges

# prod nodes: larger, 3-9 spanning all AZs
node_instance_types = ["m5.xlarge"]
node_desired_size   = 3
node_min_size       = 3
node_max_size       = 9

# --- RDS (Aurora PostgreSQL) — HA ---
rds_instance_class = "db.r6g.large"
rds_instance_count = 2          # writer + reader across AZs
rds_database_name  = "demo"

# --- Add-on chart versions (pin deliberately) ---
aws_load_balancer_controller_chart_version = "1.8.1"
metrics_server_chart_version               = "3.12.1"

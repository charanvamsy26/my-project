    {
      "type": "timeseries",
      "title": "Request Rate (req/s) by status",
      "description": "Throughput from load-test/k6, stacked by HTTP status class. During burn the 5xx band appears on top. Series: job:demo_api_requests_by_status:rate5m (recording-rules.yaml).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },

# =============================================================================
# my-project .gitignore
# Goal: never commit state, secrets, build junk, or local clutter — but DO
# commit example tfvars and the Terraform provider lock files (.terraform.lock.hcl).
# =============================================================================

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
# Local provider/module cache and plugin dirs.
**/.terraform/
.terraformrc
terraform.rc

# State and backups — NEVER commit (lives in the S3 remote backend).
*.tfstate
*.tfstate.*
*.tfstate.backup

# Saved plans and crash logs.
*.tfplan
tfplan
crash.log
crash.*.log

# Variable files contain real values/secrets — ignore them...
*.tfvars
*.tfvars.json
# ...but ALWAYS keep the committed examples and overrides.
!*.tfvars.example
!example.tfvars
!*.auto.tfvars.example

# Keep the dependency lock files committed for reproducible provider versions.
# (.terraform.lock.hcl is intentionally NOT ignored.)

# -----------------------------------------------------------------------------
# Python (demo-api)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# (.dockerignore is committed; this just keeps stray build artifacts out.)
*.tar
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Helm / Kubernetes
# -----------------------------------------------------------------------------
# Packaged chart archives and fetched dependencies — built artifacts, not source.
**/charts/*.tgz
**/charts/*/charts/
**/Chart.lock
# Rendered output / local kubeconfigs.
*.rendered.yaml
kubeconfig
kubeconfig-*
*.kubeconfig

# -----------------------------------------------------------------------------
# Node (if any tooling is added)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
secrets.*
*.pem
*.key
*.p12
*.pfx
credentials
.aws/
.kube/config

# -----------------------------------------------------------------------------
# OS / editor / misc
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.tmp
*.log
logs/

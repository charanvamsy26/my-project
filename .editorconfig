# EditorConfig: consistent whitespace/charset across editors and contributors.
# https://editorconfig.org
#
# Convention recap (see repo README): kebab-case for k8s/files, snake_case for
# Terraform variables. This file enforces the *formatting*, not the naming.

root = true

# Defaults for every file.
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Terraform / HCL — HashiCorp canonical style is 2-space indent.
[*.{tf,tfvars,hcl}]
indent_size = 2

# Python — PEP 8 uses 4 spaces.
[*.py]
indent_size = 4
max_line_length = 100

# Makefiles REQUIRE real tabs for recipes.
[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

# Go (in case helper tooling is added later) uses tabs.
[*.go]
indent_style = tab

# Markdown — trailing whitespace can be a hard line break, so don't trim it.
[*.md]
trim_trailing_whitespace = false

# YAML / JSON — 2 spaces (matches yamllint + k8s conventions).
[*.{yml,yaml,json}]
indent_size = 2

# Shell scripts.
[*.sh]
indent_size = 2

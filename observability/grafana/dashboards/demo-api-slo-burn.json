        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "slo:error_budget:remaining_ratio30d{service=\"demo-api\"}",
          "legendFormat": "budget remaining",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Burn rate — fast (page) vs slow (ticket)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Error-Budget Burn Rate — fast (1h) & slow (6h)",
      "description": "Burn rate = (window error ratio) / error budget. 1× spends the 30d budget in 30d. Thresholds: 14.4× fast-page, 6× slow-page, 3× ticket. Fast (1h) reacts within minutes of chaos; slow (6h) lags then catches up. Series: slo:burn_rate:fast / slo:burn_rate:slow (burn-demo-rules.yaml).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 14 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fast burn (1h)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "slow burn (6h)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "slo:burn_rate:fast{service=\"demo-api\"}",
          "legendFormat": "fast burn (1h)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "slo:burn_rate:slow{service=\"demo-api\"}",
          "legendFormat": "slow burn (6h)",
          "refId": "B"
        }
